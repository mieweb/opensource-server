{
  "nodemonConfig": {
    "ignore": [
      "certs",
      "client"
    ]
  },
  "scripts": {
    "dev": "nodemon server.js",
    "db:migrate": "sequelize db:migrate && sequelize db:seed:all",
    "job-runner": "node job-runner.js",
    "client:install": "npm --prefix client install",
    "client:dev": "npm --prefix client run dev",
    "client:build": "npm --prefix client run build",
    "client:preview": "npm --prefix client run preview",
    "client:type-check": "npm --prefix client run type-check"
  },
  "dependencies": {
    "argon2": "^0.44.0",
    "axios": "^1.15.2",
    "connect-flash": "^0.1.1",
    "cookie-parser": "^1.4.7",
    "csrf-csrf": "^4.0.3",
    "dotenv": "^17.2.3",
    "ejs": "^3.1.10",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.1",
    "express-session": "^1.19.0",
    "express-session-sequelize": "^2.3.0",
    "method-override": "^3.0.0",
    "morgan": "^1.10.1",
    "nodemailer": "^8.0.5",
    "pg": "^8.16.3",
    "qrcode": "^1.5.4",
    "sequelize": "^6.37.8",
    "sequelize-cli": "^6.6.3",
    "swagger-ui-express": "^5.0.1",
    "yamljs": "^0.3.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.10"
  }
}
